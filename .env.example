# Copy this file to .env (or export in your shell) and fill in real values.
# .env is gitignored — do not commit real credentials.

# Network cameras are configured in cameras.json (also gitignored). See
# cameras.json.example for the schema. No camera credentials belong in
# this file.

# Optional: override Ollama server URL
# OLLAMA_BASE_URL=http://localhost:11434

# Telegram — required for Kid Monitor Mode alerts + periodic summaries.
# Create a bot via @BotFather, send it a message, then look up your chat ID
# at https://api.telegram.org/bot<TOKEN>/getUpdates. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
