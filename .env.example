# Copy this file to .env (or export in your shell) and fill in real values.
# .env is gitignored — do not commit real credentials.

# TP-Link Tapo "Camera Account" — set up in the Tapo app under
# Advanced Settings → Camera Account, then enable RTSP/ONVIF.
TAPO_USER=your_camera_account_username
TAPO_PASS=your_camera_account_password
TAPO_HOST=192.168.4.243

# Optional: override Ollama server URL
# OLLAMA_BASE_URL=http://localhost:11434
